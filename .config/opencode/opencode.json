{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "bigquery": {
      "type": "local",
      "command": ["/Users/rodrigo.soares/bin/toolbox", "--prebuilt", "bigquery", "--stdio"],
      "enabled" : false,
      "environment": {
        "BIGQUERY_PROJECT": "{file:~/.config/opencode/.secrets}"
      }
    },
    "financecore": {
      "type": "remote",
      "url": "http://localhost:5001/mcp",
      "enabled": false,
      "headers": {
        "X-Tenant": "ie"
      }
    },
    "calendar": {
      "type": "local",
      "command": [
        "/Users/rodrigo.soares/personal/projects/mcp-macos-calendar/.build/debug/MCPMacOSCalendar",
        "--transport",
        "stdio"
      ],
      "enabled": false 
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false 
    },
    "things3": {
      "type": "local",
      "command": [
        "/Users/rodrigo.soares/personal/projects/mcp-things3/.build/debug/MCPThings3"
      ],
      "enabled": false 
    },
    "anki": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@ankimcp/anki-mcp-server",
        "--stdio"
      ],
      "environment": {
        "ANKI_CONNECT_URL": "http://localhost:8765"
      },
      "enabled": false 
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  "model": "github-copilot/claude-sonnet-4.6",
  "autoupdate": "notify",
  "lsp": {
    "csharp": {
      "disabled": true
    },
    "roslyn": {
      "command": [
        "/Users/rodrigo.soares/.local/share/nvim/mason/bin/roslyn",
        "--logLevel=Information",
        "--extensionLogDirectory=/tmp/roslyn-logs",
        "--stdio"
      ],
      "extensions": [
        ".cs"
      ]
    }
  },
  "plugin": []
}
